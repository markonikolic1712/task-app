# base_url je definisan u vite.config.js
# uradio sam deploy backenda na Railway i ovo je target URL
VITE_API_URL=https://task-app-production-f719.up.railway.app

# da bi se vue projekat servirao iz spring-boot projekta sa ovim dole treba da se uradi 'npm run build'
# front aplikacija se build-uje u dist folderu i sadrzaj dist foldera treba prekopirati u spring-boot /resources/static folder
# kada se pokrene spring-boot frontend aplikacija ce biti dostupna na http://localhost:8080
# VITE_API_URL=http://localhost:8080